# ══════════════════════════════════════════════════════════════════════════════
# BuildTrack Backend — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Core ───────────────────────────────────────────────────────────────────────
NODE_ENV=development          # "development" | "production"
PORT=5000                     # Render sets this automatically — keep 5000 locally

# ── URLs ───────────────────────────────────────────────────────────────────────
# Local development
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# Production (replace with your actual Render/Vercel URLs)
# FRONTEND_URL=https://your-app.vercel.app
# CLIENT_URL=https://your-app.vercel.app
# BACKEND_URL=https://your-api.onrender.com

# ── Auth ───────────────────────────────────────────────────────────────────────
# REQUIRED — must be a long, random, unguessable string (min 32 chars)
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_very_long_random_secret_at_least_32_chars

# ── Database ───────────────────────────────────────────────────────────────────
# REQUIRED — MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/buildtrack?retryWrites=true&w=majority

# ── Cloudinary (image / file uploads) ─────────────────────────────────────────
# REQUIRED — get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Google OAuth ───────────────────────────────────────────────────────────────
# OPTIONAL — leave blank to disable Google login
# Get credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must include: <BACKEND_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Gemini AI (voice parsing) ──────────────────────────────────────────────────
# OPTIONAL — leave blank to fall back to local rule-based parser
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── SMTP (password reset emails) ──────────────────────────────────────────────
# OPTIONAL — leave blank to log reset links to console instead
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false           # true for port 465
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="BuildTrack" <your@gmail.com>
